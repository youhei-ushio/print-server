# Angie プリントサーバー 環境設定例
# 仕様書: docs/print-server-specification.md
#
# 使用方法:
# 1. このファイルを .env にコピー
# 2. 各項目を環境に合わせて設定
# 3. プリントサーバーを起動

# =============================================
# データベース接続設定
# =============================================

# SQL Server のホスト名またはIPアドレス
# 開発環境: Docker内のSQL Serverコンテナ
# 本番環境: 実際のSQL Serverのアドレス
DB_SERVER=

# データベース名（通常は MKSystem 固定）
DB_DATABASE=MKSystem

# データベース認証設定
# Windows認証を使用する場合: 下記2項目を空文字またはコメントアウト
# SQL Server認証を使用する場合: ユーザー名とパスワードを設定
DB_USER=
DB_PASSWORD=

# ODBC ドライバー名
# Windows: {ODBC Driver 17 for SQL Server}
# Linux: {ODBC Driver 18 for SQL Server}
DB_DRIVER={ODBC Driver 17 for SQL Server}

# データベース接続タイムアウト（秒）
DB_TIMEOUT=30

# =============================================
# 印刷システム設定
# =============================================

# キューポーリング間隔（秒）
# 推奨値: 5秒（負荷とレスポンスのバランス）
PRINT_POLL_INTERVAL=5

# 最大リトライ回数
# 印刷失敗時の自動リトライ回数
PRINT_MAX_RETRY=3

# 印刷タイムアウト（秒）
# Chrome での PDF 生成とプリンター送信の制限時間
PRINT_TIMEOUT=30

# Chrome 実行パス
# Windows: chrome.exe (PATH に含まれている場合)
# Linux: /usr/bin/google-chrome
CHROME_PATH=chrome.exe

# =============================================
# ログ設定
# =============================================

# ログレベル
# DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ログファイルパス
# 相対パス（プリントサーバーディレクトリからの相対）
LOG_FILE=logs/print_server.log

# ログファイル最大サイズ（バイト）
# 10MB = 10485760 バイト
LOG_MAX_SIZE=10485760

# ログファイル保持数
# ローテーション時に保持するファイル数
LOG_MAX_FILES=5

# =============================================
# 環境別設定例
# =============================================

# 開発環境の例（Docker + Windows認証）:
# DB_SERVER=172.27.83.99
# DB_USER=
# DB_PASSWORD=
# PRINT_POLL_INTERVAL=5
# LOG_LEVEL=INFO

# 本番環境の例（SQL Server認証）:
# DB_SERVER=production-sql-server.example.com
# DB_USER=print_server_user
# DB_PASSWORD=your_secure_password
# PRINT_POLL_INTERVAL=3
# LOG_LEVEL=WARNING
# PRINT_TIMEOUT=60

# テスト環境の例（Windows認証）:
# DB_SERVER=test-sql-server.example.com
# DB_USER=
# DB_PASSWORD=
# PRINT_POLL_INTERVAL=10
# LOG_LEVEL=DEBUG
# PRINT_MAX_RETRY=1
